<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>JasperFx.RuntimeCompiler</id>
    <version>4.4.0</version>
    <authors>Jeremy D. Miller,Jaedyn Tonee</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>http://github.com/jasperfx/jasperfx</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/JasperFx/jasperfx/refs/heads/main/logo.jpg</iconUrl>
    <description>Runtime Roslyn Compilation and Code Generation Chicanery</description>
    <repository type="git" url="https://github.com/JasperFx/jasperfx" branch="refs/heads/main" commit="bf45c6f73fd4d7db2345cf1bedaa460301f65822" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="JasperFx" version="1.18.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis" version="[4.14.0, 6.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis.CSharp" version="[4.14.0, 6.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis.Scripting" version="[4.14.0, 6.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="8.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="JasperFx" version="1.18.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis" version="[4.14.0, 6.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis.CSharp" version="[4.14.0, 6.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis.Scripting" version="[4.14.0, 6.0.0)" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="9.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net10.0">
        <dependency id="JasperFx" version="1.18.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis" version="5.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis.CSharp" version="5.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.CodeAnalysis.Scripting" version="5.0.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="10.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>